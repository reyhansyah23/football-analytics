FROM python:3.11-slim

WORKDIR /app

# Copy requirements first (for better caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy everything from your local 'etl' folder into the container's '/app'
COPY . .

# IMPORTANT: Make sure 'main.py' is the correct name of your script!
CMD ["python", "main.py"]